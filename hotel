
DROP DATABASE IF EXISTS hotel_db;
CREATE DATABASE hotel_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE hotel_db;

-- 1. Пользователи (сотрудники и клиенты)
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) NOT NULL UNIQUE,
    password VARCHAR(50) NOT NULL,
    role VARCHAR(20) NOT NULL,          -- admin, manager, client, guest
    full_name VARCHAR(100) NOT NULL,
    phone VARCHAR(20),
    email VARCHAR(100)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 2. Категории номеров (например, "Стандарт", "Люкс", "Семейный", "Президентский")
CREATE TABLE room_categories (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(50) NOT NULL UNIQUE,
    description TEXT,
    base_price DECIMAL(10,2) NOT NULL      -- базовая цена за ночь
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 3. Удобства номера (кондиционер, wi-fi, телевизор, мини-бар и т.д.)
CREATE TABLE amenities (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(50) NOT NULL UNIQUE,
    icon VARCHAR(50)                       -- можно хранить имя иконки
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 4. Связь номеров и удобств (многие ко многим)
CREATE TABLE room_amenities (
    room_id INT NOT NULL,
    amenity_id INT NOT NULL,
    PRIMARY KEY (room_id, amenity_id),
    FOREIGN KEY (room_id) REFERENCES rooms(id) ON DELETE CASCADE,
    FOREIGN KEY (amenity_id) REFERENCES amenities(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 5. Номера (аналог "products" в вашем коде)
CREATE TABLE rooms (
    id INT PRIMARY KEY AUTO_INCREMENT,
    room_number VARCHAR(10) NOT NULL UNIQUE,   -- например, "101", "A-12"
    category_id INT NOT NULL,
    floor INT,
    capacity INT DEFAULT 2,                    -- количество мест
    price_per_night DECIMAL(10,2) NOT NULL,
    discount DECIMAL(5,2) DEFAULT 0,
    photo_path VARCHAR(255),
    status VARCHAR(20) DEFAULT 'available',    -- available, booked, maintenance
    description TEXT,
    FOREIGN KEY (category_id) REFERENCES room_categories(id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 6. Бронирования (аналог "orders" в вашем коде)
CREATE TABLE bookings (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) NOT NULL,            -- клиент (логин из users)
    room_id INT NOT NULL,
    check_in_date DATE NOT NULL,
    check_out_date DATE NOT NULL,
    guest_count INT DEFAULT 1,
    total_price DECIMAL(10,2) NOT NULL,
    status VARCHAR(20) DEFAULT 'pending',     -- pending, confirmed, checked_in, checked_out, cancelled
    booking_date DATETIME DEFAULT CURRENT_TIMESTAMP,
    special_requests TEXT,
    FOREIGN KEY (room_id) REFERENCES rooms(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 7. Дополнительные услуги (питание, трансфер, экскурсии и т.д.)
CREATE TABLE services (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    price DECIMAL(10,2) NOT NULL,
    unit VARCHAR(20) DEFAULT 'шт',
    description TEXT
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 8. Связь бронирований и услуг (заказанные услуги к конкретному бронированию)
CREATE TABLE booking_services (
    booking_id INT NOT NULL,
    service_id INT NOT NULL,
    quantity INT DEFAULT 1,
    price_at_booking DECIMAL(10,2) NOT NULL,   -- цена на момент заказа
    PRIMARY KEY (booking_id, service_id),
    FOREIGN KEY (booking_id) REFERENCES bookings(id) ON DELETE CASCADE,
    FOREIGN KEY (service_id) REFERENCES services(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- 9. Отзывы гостей
CREATE TABLE reviews (
    id INT PRIMARY KEY AUTO_INCREMENT,
    booking_id INT NOT NULL,
    username VARCHAR(50) NOT NULL,
    rating INT CHECK (rating BETWEEN 1 AND 5),
    comment TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (booking_id) REFERENCES bookings(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- Индексы для ускорения
CREATE INDEX idx_rooms_number ON rooms(room_number);
CREATE INDEX idx_rooms_status ON rooms(status);
CREATE INDEX idx_bookings_dates ON bookings(check_in_date, check_out_date);
CREATE INDEX idx_bookings_username ON bookings(username);
CREATE INDEX idx_bookings_status ON bookings(status);

